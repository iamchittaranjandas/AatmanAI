<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:AatmanAI.Converters"
             x:Class="AatmanAI.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Global Converters -->
            <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <converters:RelativeTimeConverter x:Key="RelativeTimeConverter"/>
            <converters:FadedOpacityConverter x:Key="FadedOpacityConverter"/>
            <converters:IsNotEmptyConverter x:Key="IsNotEmptyConverter"/>
            <converters:TimeColorConverter x:Key="TimeColorConverter"/>
            <converters:BadgeBgConverter x:Key="BadgeBgConverter"/>
            <converters:BadgeBorderConverter x:Key="BadgeBorderConverter"/>
            <converters:BadgeTextConverter x:Key="BadgeTextConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
